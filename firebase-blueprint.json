{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile settings and metrics",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "role": { "type": "string" },
        "balanceEGP": { "type": "number" },
        "monthlySavingsGoal": { "type": "number" },
        "salary": { "type": "number" },
        "currency": { "type": "string" },
        "theme": { "type": "string", "enum": ["light", "dark"] }
      },
      "required": ["name", "email", "avatarUrl", "role", "balanceEGP", "monthlySavingsGoal"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Financial income & expense records",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["income", "expense"] },
        "category": { "type": "string" },
        "date": { "type": "string" },
        "description": { "type": "string" },
        "invoiceNo": { "type": "string" },
        "attachmentName": { "type": "string" }
      },
      "required": ["id", "title", "amount", "type", "category", "date"]
    },
    "Budget": {
      "title": "Budget",
      "description": "Monthly category budgets",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "category": { "type": "string" },
        "limitAmount": { "type": "number" },
        "spentAmount": { "type": "number" },
        "period": { "type": "string" }
      },
      "required": ["id", "category", "limitAmount", "spentAmount", "period"]
    },
    "SavingsGoal": {
      "title": "SavingsGoal",
      "description": "Ad-hoc savings targets",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "targetAmount": { "type": "number" },
        "currentAmount": { "type": "number" },
        "dueDate": { "type": "string" },
        "category": { "type": "string" }
      },
      "required": ["id", "title", "targetAmount", "currentAmount", "dueDate", "category"]
    },
    "Debt": {
      "title": "Debt",
      "description": "Loan and collection accounts",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "contactName": { "type": "string" },
        "amount": { "type": "number" },
        "paidAmount": { "type": "number" },
        "dueDate": { "type": "string" },
        "type": { "type": "string", "enum": ["to_pay", "to_collect"] }
      },
      "required": ["id", "contactName", "amount", "paidAmount", "dueDate", "type"]
    },
    "Subscription": {
      "title": "Subscription",
      "description": "Recurring bill plans",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "amount": { "type": "number" },
        "billingCycle": { "type": "string", "enum": ["monthly", "yearly"] },
        "nextBillingDate": { "type": "string" },
        "category": { "type": "string" },
        "isActive": { "type": "boolean" }
      },
      "required": ["id", "name", "amount", "billingCycle", "nextBillingDate", "category", "isActive"]
    },
    "Task": {
      "title": "Task",
      "description": "Commercial tasks to perform",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "completed": { "type": "boolean" },
        "priority": { "type": "string", "enum": ["high", "medium", "low"] },
        "category": { "type": "string" },
        "dueDate": { "type": "string" },
        "time": { "type": "string" }
      },
      "required": ["id", "title", "completed", "priority", "category", "dueDate"]
    },
    "Habit": {
      "title": "Habit",
      "description": "Streaks and daily habit lists",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "streak": { "type": "number" },
        "completedToday": { "type": "boolean" }
      },
      "required": ["id", "name", "streak", "completedToday"]
    },
    "Invoice": {
      "title": "Invoice",
      "description": "Regulatory tax invoices",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "invoiceNumber": { "type": "string" },
        "clientName": { "type": "string" },
        "clientEmail": { "type": "string" },
        "issueDate": { "type": "string" },
        "dueDate": { "type": "string" },
        "status": { "type": "string", "enum": ["paid", "unpaid", "draft"] },
        "taxRate": { "type": "number" },
        "discount": { "type": "number" }
      },
      "required": ["id", "invoiceNumber", "clientName", "clientEmail", "issueDate", "dueDate", "status", "taxRate", "discount"]
    },
    "FileDoc": {
      "title": "FileDoc",
      "description": "Cloud document storage check logs",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "size": { "type": "string" },
        "mimeType": { "type": "string" },
        "uploadDate": { "type": "string" }
      },
      "required": ["id", "name", "size", "mimeType", "uploadDate"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "Conversation logs with MORV AI",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "sender": { "type": "string", "enum": ["user", "assistant"] },
        "text": { "type": "string" },
        "timestamp": { "type": "string" }
      },
      "required": ["id", "sender", "text", "timestamp"]
    },
    "ReceiptScan": {
      "title": "ReceiptScan",
      "description": "Scanned receipt OCR tracking logs",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "vendor": { "type": "string" },
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "date": { "type": "string" },
        "confidence": { "type": "number" },
        "extractedItems": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "vendor", "amount", "category", "date", "confidence"]
    },
    "AppNotification": {
      "title": "AppNotification",
      "description": "User persistent notifications and alerts",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["info", "success", "warning", "error"] },
        "timestamp": { "type": "string" },
        "isRead": { "type": "boolean" }
      },
      "required": ["id", "title", "message", "type", "timestamp", "isRead"]
    },
    "AnalyticsHistoryRecord": {
      "title": "AnalyticsHistoryRecord",
      "description": "Calculated analytics summaries and indicators for trends",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "timestamp": { "type": "string" },
        "totalIncome": { "type": "number" },
        "totalExpenses": { "type": "number" },
        "netSavings": { "type": "number" },
        "savingsRate": { "type": "number" },
        "overspendingStatus": { "type": "string", "enum": ["healthy", "warning", "critical"] },
        "savingsPrediction": { "type": "string" }
      },
      "required": ["id", "timestamp", "totalIncome", "totalExpenses", "netSavings", "savingsRate", "overspendingStatus", "savingsPrediction"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Primary user profile database"
    },
    "/users/{userId}/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Income and expenditures history"
    },
    "/users/{userId}/budgets/{budgetId}": {
      "schema": "Budget",
      "description": "Budget definitions"
    },
    "/users/{userId}/savingsGoals/{goalId}": {
      "schema": "SavingsGoal",
      "description": "Financial savings milestones"
    },
    "/users/{userId}/debts/{debtId}": {
      "schema": "Debt",
      "description": "User lending & debit accounts"
    },
    "/users/{userId}/subscriptions/{subId}": {
      "schema": "Subscription",
      "description": "User subscriptions tracker"
    },
    "/users/{userId}/tasks/{taskId}": {
      "schema": "Task",
      "description": "Daily work/business checklist tasks"
    },
    "/users/{userId}/habits/{habitId}": {
      "schema": "Habit",
      "description": "Self-motivated streaks habits tracker"
    },
    "/users/{userId}/invoices/{invoiceId}": {
      "schema": "Invoice",
      "description": "Invoicing module data structure"
    },
    "/users/{userId}/files/{fileId}": {
      "schema": "FileDoc",
      "description": "Uploaded private ledger file registry records"
    },
    "/users/{userId}/chatHistory/{chatId}": {
      "schema": "ChatMessage",
      "description": "Interactive AI speech/chat transcript archives"
    },
    "/users/{userId}/receiptScans/{scanId}": {
      "schema": "ReceiptScan",
      "description": "Scanned receipt OCR archive"
    },
    "/users/{userId}/notifications/{notificationId}": {
      "schema": "AppNotification",
      "description": "Persistent transactional notifications"
    },
    "/users/{userId}/analyticsHistory/{recordId}": {
      "schema": "AnalyticsHistoryRecord",
      "description": "Historical financial snapshots and forecasting metrics"
    }
  }
}
